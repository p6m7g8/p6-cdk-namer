{
  "name": "p6-cdk-namer",
  "description": "Sets the AWS IAM Account Alias with a Custom Resource",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/p6m7g8/p6-cdk-namer.git"
  },
  "scripts": {
    "build": "pnpm run compile && pnpm run lint && pnpm run jsii:docgen && pnpm run test && pnpm run jsii:pacmak:parallel",
    "compile": "pnpm tsc:compile && pnpm run jsii:compile",
    "diagram": "pnpm run synth && pnpm run diagram:png && pnpm run diagram:cytoscape && pnpm run diagram:serve",
    "diagram:cytoscape": "pnpm cdk-dia --target-path assets --rendering cytoscape-html -- ts-node bin/visualize.ts",
    "diagram:png": "pnpm cdk-dia --target-path assets/diagram.png -- ts-node bin/visualize.ts",
    "diagram:serve": "pnpm http-server assets -o",
    "jsii:compile": "pnpm jsii compile --verbose -c tsconfig.dev.json",
    "jsii:pacmak:parallel": "pnpm jsii-pacmak --verbose --parallel --targets js,python,dotnet,java,go",
    "jsii:docgen": "pnpm jsii-docgen -v -o API.md",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "synth": "pnpm run build && pnpm cdk synth",
    "test": "node --trace-deprecation ./node_modules/jest/bin/jest.js  --config jest.config.js --coverage --updateSnapshot",
    "test:watch": "node --trace-deprecation ./node_modules/jest/bin/jest.js  --config jest.config.js --watch --coverage --updateSnapshot",
    "tsc:compile": "pnpm tsc -p tsconfig.dev.json"
  },
  "author": {
    "name": "Philip M. Gollucci",
    "email": "pgollucci@p6m7g8.com",
    "organization": true
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.8.0",
    "@swc-node/register": "^1.10.9",
    "@types/aws-lambda": "^8.10.145",
    "@types/jest": "^29.5.14",
    "@types/node": "22.8.1",
    "@typescript-eslint/eslint-plugin": "^8.11.0",
    "@typescript-eslint/parser": "^8.11.0",
    "aws-cdk": "^2.164.1",
    "aws-cdk-lib": "2.164.1",
    "cdk-dia": "^0.11.0",
    "constructs": "10.4.2",
    "esbuild": "^0.24.0",
    "eslint": "^9.13.0",
    "eslint-plugin-import": "^2.31.0",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "jsii": "^5.5.4",
    "jsii-docgen": "^10.5.5",
    "jsii-pacmak": "^1.104.0",
    "publib": "^0.2.906",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  },
  "peerDependencies": {
    "aws-cdk-lib": "2.164.1",
    "constructs": "^10.4.2"
  },
  "dependencies": {
    "@types/aws-lambda": "^8.10.145",
    "aws-cdk-lib": "2.164.1",
    "aws-sdk": "^2.1691.0",
    "cdk-iam-floyd": "^0.658.0",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  },
  "bundledDependencies": [
    "@types/aws-lambda",
    "aws-sdk",
    "cdk-iam-floyd",
    "source-map-support"
  ],
  "keywords": [
    "account",
    "alias",
    "aws",
    "cdk",
    "iam",
    "landing zone"
  ],
  "main": "lib/index.js",
  "types": "src/index.d.ts",
  "license": "Apache-2.0",
  "version": "0.9.0",
  "packageManager": "pnpm@9.12.2+sha512.22721b3a11f81661ae1ec68ce1a7b879425a1ca5b991c975b074ac220b187ce56c708fe5db69f4c962c989452eee76c82877f4ee80f474cebd61ee13461b6228",
  "jsii": {
    "outdir": "dist",
    "tsc": {
      "outDir": "lib",
      "rootDir": "src"
    },
    "targets": {
      "java": {
        "package": "com.github.p6m7g8.p6namer",
        "maven": {
          "groupId": "com.github.p6m7g8",
          "artifactId": "p6-namer"
        }
      },
      "python": {
        "distName": "p6-namer",
        "module": "p6_namer"
      },
      "dotnet": {
        "namespace": "P6m7g8.P6Namer",
        "packageId": "P6m7g8.P6Namer"
      },
      "go": {
        "moduleName": "github.com/p6m7g8/p6-cdk-namer"
      }
    }
  }
}
